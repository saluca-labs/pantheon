# Dependencies
node_modules/
# pnpm is the canonical package manager (root pnpm-lock.yaml).
# Per-app npm/yarn lockfiles are stale and must not be committed.
apps/*/package-lock.json
apps/*/yarn.lock
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/

# Build artifacts
dist/
build/
*.egg-info/
.next/
out/
target/
*.tsbuildinfo

# Environment / secrets
.env
.env.local
.env.*.local

# Local docker-compose override (must not contain real secrets)
**/docker-compose.override.yml

# Production env / systemd files (templates only in repo)
infrastructure/incident-controller/deploy/systemd/incident-controller.env
infrastructure/**/*.env
!infrastructure/**/.env.example
!infrastructure/**/*.env.template

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local verification artifacts (created by scripts/bootstrap.sh + manual runs)
.mvp-verify.log
.bootstrap.log

# Coverage
coverage/
.nyc_output/
.pytest_cache/
htmlcov/
.coverage
