{
  "Tiresias": {
    "entityTypes": {
      "Tenant": {
        "shape": {
          "type": "Record",
          "attributes": {
            "tier": { "type": "String", "required": true },
            "max_agents": { "type": "Long", "required": true }
          }
        }
      },
      "Agent": {
        "shape": {
          "type": "Record",
          "attributes": {
            "soulkey": { "type": "String", "required": true },
            "roles": { "type": "Set", "element": { "type": "String" }, "required": true }
          }
        },
        "memberOfTypes": ["Tenant"]
      },
      "Plugin": {
        "shape": {
          "type": "Record",
          "attributes": {
            "classification": { "type": "String", "required": true },
            "owner_tenant": { "type": "String", "required": true }
          }
        }
      }
    },
    "actions": {
      "tool_call": {
        "appliesTo": {
          "principalTypes": ["Agent"],
          "resourceTypes": ["Plugin"],
          "context": {
            "type": "Record",
            "attributes": {
              "tool_name": { "type": "String", "required": true },
              "rate_count": { "type": "Long", "required": true },
              "rate_window_seconds": { "type": "Long", "required": true },
              "hour_of_day": { "type": "Long", "required": true },
              "has_approval": { "type": "Boolean", "required": true },
              "estimated_cost_usd": { "type": "Long", "required": true },
              "input_keys": { "type": "Set", "element": { "type": "String" }, "required": true }
            }
          }
        }
      },
      "read": {
        "appliesTo": {
          "principalTypes": ["Agent"],
          "resourceTypes": ["Plugin"],
          "context": {
            "type": "Record",
            "attributes": {
              "tool_name": { "type": "String", "required": true },
              "hour_of_day": { "type": "Long", "required": true }
            }
          }
        }
      },
      "write": {
        "appliesTo": {
          "principalTypes": ["Agent"],
          "resourceTypes": ["Plugin"],
          "context": {
            "type": "Record",
            "attributes": {
              "tool_name": { "type": "String", "required": true },
              "hour_of_day": { "type": "Long", "required": true },
              "has_approval": { "type": "Boolean", "required": true },
              "rate_count": { "type": "Long", "required": true }
            }
          }
        }
      }
    }
  },
  "TiresiasMatrix": {
    "entityTypes": {
      "MatrixRoom": {
        "shape": {
          "type": "Record",
          "attributes": {
            "room_alias": { "type": "String", "required": true },
            "tenant_id": { "type": "String", "required": true },
            "allowed_roles": { "type": "Set", "element": { "type": "String" }, "required": true },
            "human_write": { "type": "Boolean", "required": true }
          }
        }
      },
      "MatrixUser": {
        "shape": {
          "type": "Record",
          "attributes": {
            "agent_role": { "type": "String", "required": true },
            "tenant_id": { "type": "String", "required": true },
            "is_human": { "type": "Boolean", "required": true },
            "user_scope": { "type": "String", "required": true }
          }
        }
      }
    },
    "actions": {
      "join": {
        "appliesTo": {
          "principalTypes": ["MatrixUser"],
          "resourceTypes": ["MatrixRoom"],
          "context": { "type": "Record", "attributes": {} }
        }
      },
      "send_message": {
        "appliesTo": {
          "principalTypes": ["MatrixUser"],
          "resourceTypes": ["MatrixRoom"],
          "context": { "type": "Record", "attributes": {} }
        }
      },
      "read_history": {
        "appliesTo": {
          "principalTypes": ["MatrixUser"],
          "resourceTypes": ["MatrixRoom"],
          "context": { "type": "Record", "attributes": {} }
        }
      },
      "invite": {
        "appliesTo": {
          "principalTypes": ["MatrixUser"],
          "resourceTypes": ["MatrixRoom"],
          "context": { "type": "Record", "attributes": {} }
        }
      },
      "redact": {
        "appliesTo": {
          "principalTypes": ["MatrixUser"],
          "resourceTypes": ["MatrixRoom"],
          "context": { "type": "Record", "attributes": {} }
        }
      }
    }
  }
}
