# Tiresias Partner Program Secrets — EXAMPLE / TEMPLATE
#
# DO NOT commit actual secret values to version control.
# This file shows the required secret structure with placeholder values.
#
# === HOW TO PROVISION SECRETS ===
#
# Option A — Recommended: GCP Secret Manager + script
#   Run: scripts/provision-partner-secrets.sh --k8s \
#     --product-mssp=prod_xxx \
#     --price-mssp-monthly=price_xxx \
#     --price-mssp-annual=price_xxx \
#     --product-tenant=prod_xxx \
#     --price-tenant=price_xxx
#
#   This script pulls sensitive values from GCP Secret Manager and combines
#   them with product/price IDs to create the Kubernetes secret via kubectl,
#   never writing values to disk or git.
#
# Option B — Manual: create directly via kubectl (no file on disk):
#
#   kubectl create secret generic tiresias-partner-secrets \
#     --namespace tiresias \
#     --from-literal=stripe-partner-webhook-secret='whsec_...' \
#     --from-literal=stripe-connect-client-id='ca_...' \
#     --from-literal=partner-ops-slack-webhook='https://hooks.slack.com/services/...' \
#     --from-literal=stripe-partner-product-mssp='prod_xxx' \
#     --from-literal=stripe-partner-price-mssp-monthly='price_xxx' \
#     --from-literal=stripe-partner-price-mssp-annual='price_xxx' \
#     --from-literal=stripe-partner-product-tenant='prod_xxx' \
#     --from-literal=stripe-partner-price-tenant='price_xxx'
#
# === SECRET DESCRIPTIONS ===
# stripe-partner-webhook-secret      — Stripe webhook signing secret for the partner endpoint (whsec_...)
# stripe-connect-client-id           — Stripe Connect OAuth client ID for partner onboarding (ca_...)
# partner-ops-slack-webhook          — Slack incoming webhook URL for #partner-ops notifications
# stripe-partner-product-mssp        — Stripe product ID for "Tiresias MSSP Partner" (prod_...)
# stripe-partner-price-mssp-monthly  — Stripe price ID for MSSP monthly plan, $4,999/mo (price_...)
# stripe-partner-price-mssp-annual   — Stripe price ID for MSSP annual plan, $49,999/yr (price_...)
# stripe-partner-product-tenant      — Stripe product ID for "MSSP Per-Tenant Add-on" (prod_...)
# stripe-partner-price-tenant        — Stripe price ID for per-tenant metered usage, $199/unit/mo (price_...)
---
apiVersion: v1
kind: Secret
metadata:
  name: tiresias-partner-secrets
  namespace: tiresias
  labels:
    app.kubernetes.io/part-of: tiresias
    app.kubernetes.io/component: partner
type: Opaque
data:
  stripe-partner-webhook-secret: "<base64-encoded-value>"
  stripe-connect-client-id: "<base64-encoded-value>"
  partner-ops-slack-webhook: "<base64-encoded-value>"
  stripe-partner-product-mssp: "<base64-encoded-value>"
  stripe-partner-price-mssp-monthly: "<base64-encoded-value>"
  stripe-partner-price-mssp-annual: "<base64-encoded-value>"
  stripe-partner-product-tenant: "<base64-encoded-value>"
  stripe-partner-price-tenant: "<base64-encoded-value>"
