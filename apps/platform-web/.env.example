# ─── apps/platform-web — local env example ───────────────────────────────────
# These values mirror the root .env.example. The platform-web BFF reads from
# the root .env when run via `pnpm dev`; this file documents the subset of
# variables specific to / required by the Next.js app. Copy values from the
# repo-root .env.example or .env at bootstrap time.

# Backend API (FastAPI). Matches API_PUBLIC_URL in root .env.example.
API_PUBLIC_URL=http://localhost:8000

# Public origin for the Next.js app. Matches WEB_PUBLIC_URL in root .env.
WEB_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: separate Postgres URL for BFF permission overrides.
# Defaults to the root-level DATABASE_URL when unset.
# DATABASE_URL=postgresql://platform:platform@localhost:5432/platform
