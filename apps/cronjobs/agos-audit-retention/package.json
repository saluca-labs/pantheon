{
  "name": "@pantheon-cronjobs/agos-audit-retention",
  "version": "0.1.0",
  "private": true,
  "description": "Nightly retention sweep on agos_audit. Deletes rows older than AUDIT_RETENTION_DAYS (default 90).",
