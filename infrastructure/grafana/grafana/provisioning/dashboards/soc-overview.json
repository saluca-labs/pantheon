{
  "uid": "tiresias-soc-overview",
  "title": "TIRESIAS SOC — Security Operations Center",
  "description": "Home screen — risk posture at a glance",
  "tags": ["tiresias", "soc", "security"],
  "timezone": "utc",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "liveNow": true,
  "panels": [
    {
      "id": 1,
      "title": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "html",
        "content": "<div style=\"display:flex;justify-content:space-between;align-items:center;padding:4px 8px\"><h2 style=\"margin:0;color:#fff\">TIRESIAS SOC</h2><span style=\"background:#e02f44;padding:4px 12px;border-radius:4px;font-weight:bold;color:#fff\">LIVE</span></div>"
      }
    },
    {
      "id": 10,
      "title": "Scrape Targets Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 3 }, { "color": "green", "value": 5 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{ "expr": "count(up == 1)", "legendFormat": "Targets Up", "refId": "A" }]
    },
    {
      "id": 11,
      "title": "Targets Down",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 2 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{ "expr": "count(up == 0) OR on() vector(0)", "legendFormat": "Targets Down", "refId": "A" }]
    },
    {
      "id": 12,
      "title": "CPU — DreamServer",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{ "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\",host=\"dreamserver\"}[5m]))", "legendFormat": "CPU", "refId": "A" }]
    },
    {
      "id": 13,
      "title": "Memory — DreamServer",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{ "expr": "1 - (node_memory_MemAvailable_bytes{host=\"dreamserver\"} / node_memory_MemTotal_bytes{host=\"dreamserver\"})", "legendFormat": "Memory", "refId": "A" }]
    },
    {
      "id": 14,
      "title": "Disk — DreamServer",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "orange", "value": 0.85 }, { "color": "red", "value": 0.95 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{ "expr": "1 - (node_filesystem_avail_bytes{host=\"dreamserver\",mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{host=\"dreamserver\",mountpoint=\"/\",fstype!~\"tmpfs|overlay\"})", "legendFormat": "Disk /", "refId": "A" }]
    },
    {
      "id": 15,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }, { "color": "green", "value": 86400 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{ "expr": "node_time_seconds{host=\"dreamserver\"} - node_boot_time_seconds{host=\"dreamserver\"}", "legendFormat": "Uptime", "refId": "A" }]
    },
    {
      "id": 20,
      "title": "Log Ingestion — Last 24h",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal" }, "lineWidth": 0, "showPoints": "never" }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "sum by(job) (count_over_time({job=~\".+\"}[$__interval]))", "legendFormat": "{{job}}", "refId": "A" }
      ]
    },
    {
      "id": 21,
      "title": "Log Sources",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "legend": { "displayMode": "list", "placement": "right" }, "pieType": "donut", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [
        { "expr": "sum by(job) (count_over_time({job=~\".+\"}[$__range]))", "legendFormat": "{{job}}", "refId": "A" }
      ]
    },
    {
      "id": 30,
      "title": "Pentest Scan Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true },
      "targets": [
        { "expr": "{job=\"pentest\", source=\"scanner\"}", "refId": "A" }
      ]
    },
    {
      "id": 31,
      "title": "Auth Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true },
      "targets": [
        { "expr": "{job=\"dreamserver\", source=\"auth\"}", "refId": "A" }
      ]
    },
    {
      "id": 40,
      "title": "CPU Usage Over Time",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never" }
        }
      },
      "targets": [{ "expr": "1 - avg by(host) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))", "legendFormat": "{{host}}", "refId": "A" }]
    },
    {
      "id": 41,
      "title": "Memory Usage Over Time",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never" }
        }
      },
      "targets": [{ "expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)", "legendFormat": "{{host}}", "refId": "A" }]
    },
    {
      "id": 42,
      "title": "Network I/O — DreamServer",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" }
        }
      },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{host=\"dreamserver\",device!~\"lo|veth.*|br-.*|docker.*\"}[5m])", "legendFormat": "RX {{device}}", "refId": "A" },
        { "expr": "-rate(node_network_transmit_bytes_total{host=\"dreamserver\",device!~\"lo|veth.*|br-.*|docker.*\"}[5m])", "legendFormat": "TX {{device}}", "refId": "B" }
      ]
    },
    {
      "id": 50,
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 1, "showPoints": "never" }
        }
      },
      "targets": [{ "expr": "rate(container_cpu_usage_seconds_total{name=~\".+\"}[5m])", "legendFormat": "{{name}}", "refId": "A" }]
    },
    {
      "id": 51,
      "title": "Container Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 1, "showPoints": "never" }
        }
      },
      "targets": [{ "expr": "container_memory_usage_bytes{name=~\".+\"}", "legendFormat": "{{name}}", "refId": "A" }]
    },
    {
      "id": 60,
      "title": "Disk I/O",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" }
        }
      },
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total{host=\"dreamserver\"}[5m])", "legendFormat": "Read {{device}}", "refId": "A" },
        { "expr": "-rate(node_disk_written_bytes_total{host=\"dreamserver\"}[5m])", "legendFormat": "Write {{device}}", "refId": "B" }
      ]
    },
    {
      "id": 61,
      "title": "Filesystem Space",
      "type": "bargauge",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient" },
      "targets": [{ "expr": "node_filesystem_avail_bytes{host=\"dreamserver\",fstype!~\"tmpfs|overlay|squashfs\",mountpoint!~\"/boot.*\"}", "legendFormat": "{{mountpoint}}", "refId": "A" }]
    },
    {
      "id": 62,
      "title": "Loki Ingestion Rate",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never" }
        }
      },
      "targets": [{ "expr": "sum(rate(loki_distributor_bytes_received_total[5m]))", "legendFormat": "Ingested", "refId": "A" }]
    },
    {
      "id": 70,
      "title": "SoulWatch Detections (Pentest DB)",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 43 },
      "datasource": { "type": "postgres", "uid": "pentest-db" },
      "options": { "showHeader": true },
      "targets": [{ "rawSql": "SELECT * FROM _soulwatch_detections ORDER BY created_at DESC LIMIT 20", "format": "table", "refId": "A" }]
    },
    {
      "id": 71,
      "title": "SoulGate Request Log (Pentest DB)",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 43 },
      "datasource": { "type": "postgres", "uid": "pentest-db" },
      "options": { "showHeader": true },
      "targets": [{ "rawSql": "SELECT * FROM _soulgate_request_log ORDER BY created_at DESC LIMIT 20", "format": "table", "refId": "A" }]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(node_uname_info, nodename)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "schemaVersion": 39,
  "version": 2
}
