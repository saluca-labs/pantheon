{
  "uid": "tiresias-waf",
  "title": "Cloud Armor WAF",
  "description": "WAF rule hits, blocked requests, rate limiting, top attackers",
  "tags": ["tiresias", "security", "waf", "cloud-armor"],
  "timezone": "utc",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "html",
        "content": "<div style=\"display:flex;justify-content:space-between;align-items:center;padding:4px 8px\"><h2 style=\"margin:0;color:#fff\">CLOUD ARMOR WAF — tiresias-waf</h2><span style=\"background:#ff9830;padding:4px 12px;border-radius:4px;font-weight:bold;color:#000\">BLOCKING</span></div>"
      }
    },
    {
      "id": 10,
      "title": "Total Requests (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 2 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{ "expr": "sum(count_over_time({job=\"cloud-armor\"}[$__range]))", "refId": "A" }]
    },
    {
      "id": 11,
      "title": "Blocked (403)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 2 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 10 }, { "color": "red", "value": 100 }] } } },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{ "expr": "sum(count_over_time({job=\"cloud-armor\"} | json | outcome=\"DENY\" [$__range]))", "refId": "A" }]
    },
    {
      "id": 12,
      "title": "Rate Limited (429)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 2 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }] } } },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{ "expr": "sum(count_over_time({job=\"cloud-armor\"} | json | statusDetails=\"throttled\" [$__range]))", "refId": "A" }]
    },
    {
      "id": 13,
      "title": "Allowed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 2 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{ "expr": "sum(count_over_time({job=\"cloud-armor\"} | json | outcome=\"ALLOW\" [$__range]))", "refId": "A" }]
    },
    {
      "id": 14,
      "title": "Unique Source IPs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 2 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{ "expr": "count(sum by(src_ip) (count_over_time({job=\"cloud-armor\"} | json [$__range])))", "refId": "A" }]
    },
    {
      "id": 15,
      "title": "WAF Rules Active",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [{ "expr": "vector(11)", "legendFormat": "Rules", "refId": "A" }]
    },
    {
      "id": 20,
      "title": "Requests Over Time — Allow vs Deny",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal" }, "lineWidth": 0, "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "DENY" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "ALLOW" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum by(outcome) (count_over_time({job=\"cloud-armor\"} | json [$__interval]))", "legendFormat": "{{outcome}}", "refId": "A" }]
    },
    {
      "id": 21,
      "title": "Block Reasons",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "pieType": "donut", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [{ "expr": "sum by(rule) (count_over_time({job=\"cloud-armor\"} | json | outcome=\"DENY\" [$__range]))", "legendFormat": "{{rule}}", "refId": "A" }]
    },
    {
      "id": 30,
      "title": "WAF Rule Hit Timeline",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "bars", "fillOpacity": 70, "stacking": { "mode": "normal" }, "lineWidth": 0, "showPoints": "never" } }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "sum by(rule) (count_over_time({job=\"cloud-armor\"} | json | outcome=\"DENY\" [$__interval]))", "legendFormat": "{{rule}}", "refId": "A" }]
    },
    {
      "id": 40,
      "title": "Top Source IPs (Blocked)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }, { "color": "orange", "value": 10 }, { "color": "red", "value": 50 }] } }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "horizontal", "displayMode": "gradient" },
      "targets": [{ "expr": "topk(10, sum by(src_ip) (count_over_time({job=\"cloud-armor\"} | json | outcome=\"DENY\" [$__range])))", "legendFormat": "{{src_ip}}", "refId": "A" }]
    },
    {
      "id": 41,
      "title": "Top Targeted Paths",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "orange", "value": 10 }] } }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "horizontal", "displayMode": "gradient" },
      "targets": [{ "expr": "topk(10, sum by(request_path) (count_over_time({job=\"cloud-armor\"} | json | outcome=\"DENY\" [$__range])))", "legendFormat": "{{request_path}}", "refId": "A" }]
    },
    {
      "id": 50,
      "title": "WAF Event Log",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true },
      "targets": [{ "expr": "{job=\"cloud-armor\"}", "refId": "A" }]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "schemaVersion": 39,
  "version": 1
}
