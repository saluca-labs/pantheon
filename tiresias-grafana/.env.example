# Tiresias SOC — Environment Variables
# Copy to .env and fill in values before deployment

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_ROOT_URL=http://192.168.12.167:3001

# Pentest Target DB
PENTEST_DB_USER=tiresias
PENTEST_DB_PASSWORD=changeme

# Production Cloud SQL
PROD_DB_HOST=localhost
