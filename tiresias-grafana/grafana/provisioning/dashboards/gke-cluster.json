{
  "uid": "tiresias-gke",
  "title": "GKE \u2014 tiresias-v2 Cluster",
  "tags": ["gke", "kubernetes", "tiresias"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(kube_namespace_labels, namespace)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "tiresias",
          "value": "tiresias"
        },
        "hide": 0,
        "label": "Namespace"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Cluster Overview",
      "type": "row"
    },
    {
      "id": 1,
      "title": "Total Pods",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(kube_pod_info{namespace=~\"$namespace\"})",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "mappings": [],
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Pods Running",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(kube_pod_status_phase{namespace=~\"$namespace\",phase=\"Running\"} == 1)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "mappings": [],
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Pods Not Ready",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(kube_pod_status_ready{namespace=~\"$namespace\",condition=\"true\"} == 0) OR on() vector(0)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [],
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Container Restarts (1h)",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[1h]))",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          },
          "mappings": [],
          "decimals": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Deployments",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(kube_deployment_spec_replicas{namespace=~\"$namespace\"})",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null }
            ]
          },
          "mappings": [],
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 6,
      "title": "Available Replicas",
      "description": "Available / Desired replicas across all deployments",
      "type": "stat",
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kube_deployment_status_replicas_available{namespace=~\"$namespace\"})",
          "instant": true,
          "legendFormat": "available"
        },
        {
          "refId": "B",
          "expr": "sum(kube_deployment_spec_replicas{namespace=~\"$namespace\"})",
          "instant": true,
          "legendFormat": "desired"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "mappings": [],
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "transformations": [
        {
          "id": "calculateField",
          "options": {
            "mode": "binary",
            "reduce": { "reducer": "lastNotNull" },
            "binary": {
              "left": "available",
              "operator": "/",
              "right": "desired"
            },
            "replaceFields": false
          }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "id": 101,
      "title": "Deployment & Pod Status",
      "type": "row"
    },
    {
      "id": 7,
      "title": "Deployment Replica Status",
      "type": "table",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "kube_deployment_spec_replicas{namespace=~\"$namespace\"}",
          "instant": true,
          "format": "table",
          "legendFormat": "__auto"
        },
        {
          "refId": "B",
          "expr": "kube_deployment_status_replicas_available{namespace=~\"$namespace\"}",
          "instant": true,
          "format": "table",
          "legendFormat": "__auto"
        },
        {
          "refId": "C",
          "expr": "kube_deployment_status_replicas_ready{namespace=~\"$namespace\"}",
          "instant": true,
          "format": "table",
          "legendFormat": "__auto"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "custom": {
            "align": "center",
            "cellOptions": { "type": "auto" },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Deployment" },
            "properties": [
              { "id": "custom.width", "value": 200 },
              { "id": "custom.align", "value": "left" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Available" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "green", "value": 1 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false },
        "sortBy": [{ "displayName": "Deployment", "desc": false }]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "cluster": true,
              "instance": true,
              "job": true,
              "namespace": true,
              "uid": true,
              "container": true,
              "endpoint": true,
              "pod": true,
              "service": true
            },
            "renameByName": {
              "deployment": "Deployment",
              "Value #A": "Desired",
              "Value #B": "Available",
              "Value #C": "Ready"
            }
          }
        }
      ]
    },
    {
      "id": 8,
      "title": "Pod Status by Phase",
      "type": "piechart",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(phase) (kube_pod_status_phase{namespace=~\"$namespace\"} == 1)",
          "instant": true,
          "legendFormat": "{{phase}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Running" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Pending" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Succeeded" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Unknown" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": {
          "displayMode": "list",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "id": 102,
      "title": "Restarts & Readiness",
      "type": "row"
    },
    {
      "id": 9,
      "title": "Container Restarts Over Time",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "increase(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[5m])",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "barAlignment": 0,
            "lineWidth": 1,
            "fillOpacity": 80,
            "gradientMode": "none",
            "spanNulls": false,
            "insertNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "normal", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "tooltip": false, "viz": false, "legend": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "mappings": [],
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": ["sum"]
        }
      }
    },
    {
      "id": 10,
      "title": "Pod Ready Status Over Time",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "kube_pod_status_ready{namespace=~\"$namespace\",condition=\"true\"}",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": true,
            "insertNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "tooltip": false, "viz": false, "legend": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Not Ready", "color": "red" }, "1": { "text": "Ready", "color": "green" } } }
          ],
          "min": 0,
          "max": 1,
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 103,
      "title": "Deployment Health & Pod Age",
      "type": "row"
    },
    {
      "id": 11,
      "title": "Desired vs Available Replicas",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "kube_deployment_spec_replicas{namespace=~\"$namespace\"}",
          "legendFormat": "{{deployment}} desired"
        },
        {
          "refId": "B",
          "expr": "kube_deployment_status_replicas_available{namespace=~\"$namespace\"}",
          "legendFormat": "{{deployment}} available"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "barAlignment": 0,
            "lineWidth": 2,
            "fillOpacity": 0,
            "gradientMode": "none",
            "spanNulls": true,
            "insertNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "replicas",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "tooltip": false, "viz": false, "legend": false },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "mappings": [],
          "unit": "short",
          "decimals": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*desired$" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*available$" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "solid" } },
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "custom.fillOpacity", "value": 10 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": ["lastNotNull", "min"]
        }
      }
    },
    {
      "id": 12,
      "title": "Pod Age",
      "type": "bargauge",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - kube_pod_start_time{namespace=~\"$namespace\"}",
          "instant": true,
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-blues" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 3600 },
              { "color": "yellow", "value": 86400 },
              { "color": "orange", "value": 604800 }
            ]
          },
          "mappings": [],
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color",
        "namePlacement": "auto",
        "sizing": "auto"
      },
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "sort": [{ "field": "Value", "desc": true }]
          }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "id": 104,
      "title": "Pod Details",
      "type": "row"
    },
    {
      "id": 13,
      "title": "All Pods Detail",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "kube_pod_info{namespace=~\"$namespace\"}",
          "instant": true,
          "format": "table",
          "legendFormat": "__auto"
        },
        {
          "refId": "B",
          "expr": "kube_pod_status_phase{namespace=~\"$namespace\"} == 1",
          "instant": true,
          "format": "table",
          "legendFormat": "__auto"
        },
        {
          "refId": "C",
          "expr": "kube_pod_status_ready{namespace=~\"$namespace\",condition=\"true\"}",
          "instant": true,
          "format": "table",
          "legendFormat": "__auto"
        },
        {
          "refId": "D",
          "expr": "kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}",
          "instant": true,
          "format": "table",
          "legendFormat": "__auto"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "custom": {
            "align": "center",
            "cellOptions": { "type": "auto" },
            "inspect": false,
            "filterable": true
          }
        },
        "overrides": [
          {
