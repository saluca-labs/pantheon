# ─── Tiresias Platform — Authoritative Environment Variable Reference ──────────
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Used by platform-web (BFF) and platform-api (Python FastAPI)
DATABASE_URL=postgresql://platform:platform@localhost:5432/platform

# Optional: separate DB for BFF permission overrides (defaults to DATABASE_URL)
# BFF_DATABASE_URL=postgresql://platform:platform@localhost:5432/platform_bff

# Postgres credentials (used by docker-compose)
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform

# ─── Auth ─────────────────────────────────────────────────────────────────────
AUTH_MODE=local

# Must be at least 32 characters. Generate: openssl rand -base64 48
SESSION_SECRET=changeme-replace-with-a-real-secret-at-least-32-chars-long

# Optional: restrict cookies to a specific domain
# COOKIE_DOMAIN=.example.com

# ─── Public URLs ──────────────────────────────────────────────────────────────
WEB_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:8000

# ─── SMTP (for password-reset emails) ─────────────────────────────────────────
# In dev, mailhog catches all outgoing email (http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@localhost

# ─── Redis (optional — for distributed rate limiting) ─────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ─── Memory service (Node sidecar exposing @platform/memory over HTTP) ───────
# Consumed by platform-api (Python) via packages/memory-client/python.
MEMORY_SERVICE_URL=http://localhost:8910
MEMORY_SERVICE_KEY=changeme-memory-service-shared-secret
# Backend for the sidecar itself: sqlite (default) or postgres
MEMORY_BACKEND=sqlite
# SQLite path (when MEMORY_BACKEND=sqlite); ignored otherwise
ASPHODEL_DB=./data/memory.db
# Postgres URL (when MEMORY_BACKEND=postgres); falls back to DATABASE_URL
# ASPHODEL_DATABASE_URL=postgresql://platform:platform@localhost:5432/memory

# ─── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=info
# SERVICE_NAME=platform-api

# ─── Platform-API specific ────────────────────────────────────────────────────
# (Existing SoulAuth settings — do not remove)
# APP_VERSION=1.0.0
# ENCRYPTION_KEY=<hex-encoded-256-bit-key>
# JWT_SECRET=<your-jwt-secret>

# ─── Matrix bridge (opt-in profile: docker compose --profile matrix up) ───────
# Plan: tiresias-matrix-integration-plan.md
MATRIX_SERVER_NAME=tiresias.local

# Synapse ↔ appservice shared secrets (min 64 chars in production)
# Generate: openssl rand -hex 32
MATRIX_HS_TOKEN=changeme-hs-token-replace-me
MATRIX_AS_TOKEN=changeme-as-token-replace-me

# Synapse internal secrets (generate: openssl rand -hex 32)
MATRIX_REGISTRATION_SECRET=changeme-registration-secret-replace-me
MATRIX_MACAROON_SECRET=changeme-macaroon-secret-replace-me
MATRIX_FORM_SECRET=changeme-form-secret-replace-me

# Database used by Synapse inside the platform Postgres instance
MATRIX_POSTGRES_DB=synapse

# SoulWatch ingest URL — wired in PR D. Leave blank for PR A scaffolding.
# SOULWATCH_INGEST_URL=http://platform-api:8000/ingest/matrix

# ─── Matrix console embed (V-08, PR E) ───────────────────────────────────────
# URL the dashboard iframe at /dashboard/matrix-console points to.
# Default '/_matrix/element/' uses the same-origin rewrite in
# apps/platform-web/next.config.ts that proxies to the `element`
# Compose service. Override only if Element is exposed on a separate
# ingress (e.g. https://element.example.com/).
# NEXT_PUBLIC_MATRIX_CONSOLE_URL=/_matrix/element/
#
# Upstream the Next.js rewrite proxies to. Defaults to the in-Compose
# service name `http://element`. Override when running platform-web
# outside Compose against an external Element deployment.
# MATRIX_ELEMENT_UPSTREAM=http://element
