# Pantheon — line ending normalization
#
# Goal: every text source file is stored LF in the index and checked out LF on
# every OS. Without this, Windows clones with the default `core.autocrlf=true`
# materialise files with CRLF on disk, which breaks any test that does a
# byte-for-byte string match against a file's contents (e.g.
# apps/platform-web/src/__tests__/agentic-os/business/migration-0055.test.ts).
#
# `* text=auto eol=lf` is the canonical recipe — Git still autodetects binary
# vs text, but anything text is forced to LF.

* text=auto eol=lf

# Explicit pins for source languages we care about most.
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.sql       text eol=lf
*.sh        text eol=lf eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.svg       text eol=lf
Dockerfile  text eol=lf
*.dockerfile text eol=lf

# Treat lockfiles as text but never auto-merge — keeps diffs sane.
pnpm-lock.yaml  text eol=lf -diff
package-lock.json text eol=lf -diff

# Force CRLF for Windows-only batch files.
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Known binary types — no normalization.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tgz       binary
*.tar       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.mp3       binary
*.mp4       binary
*.wav       binary
