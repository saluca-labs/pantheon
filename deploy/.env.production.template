# Tiresias Platform — Production Environment Configuration
# --------------------------------------------------------
# Copy this file to .env and fill in REQUIRED values.
# Documentation: https://tiresias.network/docs/install
# Support: support@saluca.com

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_USER=tiresias                          # Database username
POSTGRES_PASSWORD=                              # REQUIRED — set a strong password (min 16 chars)
POSTGRES_DB=tiresias                            # Database name

# =============================================================================
# TIRESIAS PROXY — LLM Audit Proxy
# =============================================================================
TIRESIAS_TENANT_ID=                             # REQUIRED — your tenant UUID (provided at checkout)
TIRESIAS_KEK=                                   # REQUIRED — 64 hex chars, encryption master key
                                                # Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
TIRESIAS_KEK_PROVIDER=local                     # Key provider: local | aws-kms | gcp-sm
TIRESIAS_PROVIDERS=anthropic,openai             # Comma-separated LLM providers to proxy
TIRESIAS_UPSTREAM_URL=https://api.openai.com    # Default upstream for generic proxy mode
TIRESIAS_RETENTION_DAYS=90                      # Days to retain audit logs (min 1)
TIRESIAS_USAGE_RETENTION_DAYS=365               # Days to retain usage/billing data (min 1)
TIRESIAS_GENERIC_PROXY_MODE=false               # Set true to proxy any upstream, not just known providers

# Optional: AWS KMS (if TIRESIAS_KEK_PROVIDER=aws-kms)
TIRESIAS_AWS_KMS_KEY_ID=                        # OPTIONAL — AWS KMS key ARN or alias
TIRESIAS_AWS_KMS_REGION=us-east-1               # OPTIONAL — AWS region for KMS calls

# Optional: GCP Secret Manager (if TIRESIAS_KEK_PROVIDER=gcp-sm)
TIRESIAS_GCP_PROJECT_ID=                        # OPTIONAL — GCP project ID
TIRESIAS_GCP_SECRET_ID=                         # OPTIONAL — GCP secret resource ID

# Optional: Redis rate limiting
TIRESIAS_REDIS_URL=                             # OPTIONAL — e.g. redis://redis:6379 (enable rate-limit profile in compose)

# =============================================================================
# SOULAUTH — Identity & Authorization
# =============================================================================
TIRESIAS_LICENSE_KEY=                            # REQUIRED — JWT license key (provided at checkout)
SOULAUTH_LICENSE_REQUIRED=true                  # Enforce license validation on startup
SOULAUTH_LOG_LEVEL=info                         # Log verbosity: debug | info | warning | error

# JWT Signing Keys (auto-generated on first boot if empty)
SOULAUTH_JWT_PRIVATE_KEY=                       # OPTIONAL — ES256 private key PEM (leave empty for auto-gen)
SOULAUTH_JWT_PUBLIC_KEY=                        # OPTIONAL — ES256 public key PEM (leave empty for auto-gen)

# REQUIRED — HMAC secret for license JWT verification (provided at checkout)
TIRESIAS_LICENSE_SECRET=
# REQUIRED — first admin user email (created on first boot)
ADMIN_EMAIL=
# REQUIRED — first admin user password (min 12 chars)
ADMIN_PASSWORD=
# Shared secret for inter-service auth (SoulGate/SoulWatch). Generate: openssl rand -hex 32
INTERNAL_API_KEY=

# =============================================================================
# SOULGATE — API Security Gateway (internal, auto-configured)
# =============================================================================
# SoulGate reads SOULGATE_* vars from the compose environment.
# No customer configuration needed — included for completeness.

# =============================================================================
# SOULWATCH — Behavioral Analytics (internal, auto-configured)
# =============================================================================
# SoulWatch reads SOULWATCH_* vars from the compose environment.
# No customer configuration needed — included for completeness.

# =============================================================================
# IMAGE VERSION
# =============================================================================
TIRESIAS_VERSION=v3.5.0                         # Pin to a specific release tag

# =============================================================================
# PORTS (change if conflicts with existing services)
# =============================================================================
PROXY_PORT=8080                                 # Tiresias audit proxy listener port
SOULAUTH_PORT=8000                              # SoulAuth identity service port
PORTAL_PORT=3000                                # Web portal UI port
