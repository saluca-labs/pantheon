# =============================================================================
# Tiresias Partner Program — Stripe Configuration
# =============================================================================
# Copy to .env (or merge into existing .env) and fill in values.
# All IDs below are created by running scripts/stripe-partner-setup.sh
# or manually via the Stripe Dashboard.
#
# NOTE: These variables are ADDITIVE to the existing .env.example.
# Do NOT duplicate STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, or
# STRIPE_PUBLISHABLE_KEY here; those are already defined in .env.example
# and used by src/saas/billing.py, src/partner/connect.py, etc.
# =============================================================================

# =============================================================================
# Stripe Products (created via CLI or Dashboard)
# =============================================================================
# MSSP Partner Base product and prices
STRIPE_PARTNER_PRODUCT_MSSP=prod_xxx                   # "Tiresias MSSP Partner" product ID
STRIPE_PARTNER_PRICE_MSSP_MONTHLY=price_xxx             # $4,999/mo recurring
STRIPE_PARTNER_PRICE_MSSP_ANNUAL=price_xxx              # $49,999/yr recurring (~17% discount)

# Per-Tenant Add-on product and metered price
STRIPE_PARTNER_PRODUCT_TENANT_ADDON=prod_xxx            # "Tiresias MSSP Per-Tenant Add-on" product ID
STRIPE_PARTNER_PRICE_PER_TENANT=price_xxx               # $199/unit/mo metered (aggregate: last_during_period)

# =============================================================================
# Stripe Connect
# =============================================================================
# Onboarding URLs (where Stripe redirects after Express onboarding)
STRIPE_CONNECT_ONBOARD_RETURN_URL=https://tiresias.network/partner/onboard/complete
STRIPE_CONNECT_ONBOARD_REFRESH_URL=https://tiresias.network/partner/onboard/refresh

# =============================================================================
# Partner Webhook
# =============================================================================
# Signing secret for the partner-specific webhook endpoint.
# Separate from STRIPE_WEBHOOK_SECRET (which covers the platform endpoint).
STRIPE_PARTNER_WEBHOOK_SECRET=whsec_xxx                 # From Dashboard > Webhooks > partner endpoint
STRIPE_PARTNER_WEBHOOK_URL=https://api.tiresias.network/v1/stripe/partner-webhooks

# =============================================================================
# Payout Configuration
# =============================================================================
STRIPE_PARTNER_PAYOUT_DELAY_NEW=7                       # Days delay for new partners (T+7)
STRIPE_PARTNER_PAYOUT_DELAY_GRADUATED=2                 # Days delay after graduation (T+2)
STRIPE_PARTNER_GRADUATION_DAYS=90                       # Days until partner graduates to faster payouts
