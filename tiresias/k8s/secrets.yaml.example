# Tiresias Platform Secrets — EXAMPLE / TEMPLATE
#
# DO NOT commit actual secret values to version control.
# This file shows the required secret structure with placeholder values.
#
# === HOW TO PROVISION SECRETS ===
#
# Option A — Recommended: GCP Secret Manager (once Secret Manager API is enabled)
#   Run: scripts/provision-k8s-secrets.sh
#   This script pulls values from GCP Secret Manager and creates the Kubernetes
#   secret via kubectl, never writing values to disk or git.
#
# Option B — Manual: create directly via kubectl (no file on disk):
#
#   kubectl create secret generic tiresias-secrets \
#     --namespace tiresias \
#     --from-literal=database-url='postgresql+asyncpg://tiresias:<pass>@127.0.0.1:5432/tiresias' \
#     --from-literal=database-url-sync='postgresql://tiresias:<pass>@127.0.0.1:5432/tiresias' \
#     --from-literal=jwt-private-key="$(cat /path/to/ec-private-key.pem)" \
#     --from-literal=jwt-public-key="$(cat /path/to/ec-public-key.pem)" \
#     --from-literal=jwt-kid='soulauth-YYYY-MM' \
#     --from-literal=stripe-secret-key='sk_live_...' \
#     --from-literal=stripe-webhook-secret='whsec_...' \
#     --from-literal=resend-api-key='re_...' \
#     --from-literal=internal-api-key='<64-char-hex>' \
#     --from-literal=metrics-auth-token='<64-char-hex>' \
#     --from-literal=tiresias-license-secret='<64-char-hex>' \
#     --from-literal=tiresias-license-key='<jwt-token>'
#
# === GENERATING SECRETS ===
#
# EC key pair (ES256):
#   openssl ecparam -name prime256v1 -genkey -noout -out ec-private.pem
#   openssl ec -in ec-private.pem -pubout -out ec-public.pem
#
# Random 64-char hex tokens:
#   openssl rand -hex 32
#
# === SECRET DESCRIPTIONS ===
# database-url          — asyncpg DSN for Cloud SQL via proxy (localhost:5432)
# database-url-sync     — sync psycopg2 DSN for Alembic migrations
# jwt-private-key       — EC P-256 private key PEM for signing JWTs
# jwt-public-key        — EC P-256 public key PEM for verifying JWTs
# jwt-kid               — key ID for rotation tracking (e.g. soulauth-2026-04)
# stripe-secret-key     — Stripe secret key (sk_live_...)
# stripe-webhook-secret — Stripe webhook signing secret (whsec_...)
# resend-api-key        — Resend transactional email API key
# internal-api-key      — Shared HMAC token between soulauth/soulgate/soulwatch
# metrics-auth-token    — Bearer token for /metrics Prometheus endpoint
# tiresias-license-secret — HMAC-SHA256 key for signing license JWTs
# tiresias-license-key  — Pre-issued enterprise license JWT
---
apiVersion: v1
kind: Secret
metadata:
  name: tiresias-secrets
  namespace: tiresias
  labels:
    app.kubernetes.io/part-of: tiresias
type: Opaque
data:
  database-url: "<base64-encoded-value>"
  database-url-sync: "<base64-encoded-value>"
  jwt-private-key: "<base64-encoded-ec-private-key-pem>"
  jwt-public-key: "<base64-encoded-ec-public-key-pem>"
  jwt-kid: "<base64-encoded-key-id>"
  stripe-secret-key: "<base64-encoded-value>"
  stripe-webhook-secret: "<base64-encoded-value>"
  resend-api-key: "<base64-encoded-value>"
  internal-api-key: "<base64-encoded-64-char-hex>"
  metrics-auth-token: "<base64-encoded-64-char-hex>"
  tiresias-license-secret: "<base64-encoded-64-char-hex>"
  tiresias-license-key: "<base64-encoded-jwt>"
