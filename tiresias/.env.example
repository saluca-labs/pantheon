# Tiresias Platform - Environment Configuration
# Copy to .env and fill in values

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
POSTGRES_USER=tiresias
POSTGRES_PASSWORD=changeme-in-production
POSTGRES_DB=tiresias

# =============================================================================
# SoulAuth - Core Identity & Authorization Engine
# =============================================================================
SOULAUTH_DEBUG=false
SOULAUTH_LOG_LEVEL=INFO
SOULAUTH_MODE=enterprise

# Database URLs (auto-constructed in docker-compose from POSTGRES_* vars)
SOULAUTH_DATABASE_URL=postgresql+asyncpg://tiresias:changeme-in-production@localhost:5432/tiresias
SOULAUTH_DATABASE_URL_SYNC=postgresql://tiresias:changeme-in-production@localhost:5432/tiresias

# JWT Keys (ES256)
# Generate with:
#   openssl ecparam -genkey -name prime256v1 -noout -out private.pem
#   openssl ec -in private.pem -pubout -out public.pem
SOULAUTH_JWT_PRIVATE_KEY_PATH=./keys/private.pem
SOULAUTH_JWT_PUBLIC_KEY_PATH=./keys/public.pem

# License (set to false for development)
TIRESIAS_LICENSE_KEY=
SOULAUTH_LICENSE_REQUIRED=false

# Policy Repository (git-synced YAML policies)
# Default: /app/policies (bundled in container via Dockerfile COPY)
# Override with a mounted volume path for on-prem git sync from an external repo
SOULAUTH_POLICY_REPO_PATH=/app/policies

# =============================================================================
# Trial & Email
# =============================================================================
# Resend API key for transactional email (trial verification)
RESEND_API_KEY=

# Base URL for verification email links
TRIAL_VERIFY_BASE_URL=https://tiresias.network

# From address for trial onboarding emails
SOULAUTH_TRIAL_FROM_EMAIL=Tiresias <tiresias.onboarding@saluca.com>

# =============================================================================
# Internal API Key (shared between SoulGate, SoulWatch, and SoulAuth)
# =============================================================================
INTERNAL_API_KEY=changeme-in-production

# =============================================================================
# Metrics & Observability
# =============================================================================
# Bearer token for /metrics endpoint authentication (leave empty for open access in dev)
METRICS_AUTH_TOKEN=

# =============================================================================
# JWT Key Rotation
# =============================================================================
# Key ID for JWT header — identifies the signing key version for rotation
# Change when rotating keys (e.g. "soulauth-2026-04")
SOULAUTH_JWT_KID=

# =============================================================================
# SoulGate - API Gateway
# =============================================================================
SOULGATE_DATABASE_URL=postgresql+asyncpg://tiresias:changeme-in-production@localhost:5432/tiresias
SOULGATE_SOULAUTH_URL=http://localhost:8000

# Action Pipeline (SoulGate → PicoClaw action execution layer)
SOULGATE_PICOCLAW_BASE_URL=http://localhost:18790
SOULGATE_PICOCLAW_ACTION_TOKEN=          # Shared secret — generate with: openssl rand -hex 32

# =============================================================================
# SoulWatch - Behavioral Analytics Sidecar
# =============================================================================
SOULWATCH_DATABASE_URL=postgresql+asyncpg://tiresias:changeme-in-production@localhost:5432/tiresias
SOULWATCH_MODE=sidecar
SOULWATCH_SOULAUTH_URL=http://localhost:8000

# =============================================================================
# Detection & Analytics
# =============================================================================
SOULAUTH_DETECTION_ENABLED=true
SOULAUTH_DETECTION_RULES_DIR=
SOULAUTH_DETECTION_PLAYBOOKS_DIR=

# =============================================================================
# SIEM Integration
# =============================================================================
SOULAUTH_SIEM_ENABLED=false
SOULAUTH_SIEM_DESTINATIONS=
# Example: SOULAUTH_SIEM_DESTINATIONS=[{"type":"splunk","hec_url":"https://splunk:8088","hec_token":"...","index":"tiresias"}]
SOULAUTH_SIEM_BUFFER_SIZE=1000
SOULAUTH_SIEM_FLUSH_INTERVAL=5

# =============================================================================
# Chatbot LLM (required for support chatbot)
# =============================================================================
OPENROUTER_API_KEY=

# =============================================================================
# Support Integrations
# =============================================================================
# Linear API key for ticket escalation (creates issues in Linear)
LINEAR_API_KEY=

# Telegram bot for critical alerts
SOULAUTH_TELEGRAM_BOT_TOKEN=
SOULAUTH_TELEGRAM_CHAT_ID=

# =============================================================================
# Portal (Next.js)
# =============================================================================
# OIDC / SSO
SOULAUTH_OIDC_SECRET_KEY=        # Fernet key for IdP client_secret encryption
SOULAUTH_OIDC_STATE_SECRET=      # HMAC secret for PKCE state signing

# Contact emails (shown to customers)
SOULAUTH_SUPPORT_EMAIL=support@tiresias.network
SOULAUTH_BILLING_EMAIL=billing@tiresias.network
SOULAUTH_CONTACT_EMAIL=contact@tiresias.network

NEXT_PUBLIC_SOULAUTH_API_URL=http://localhost:8000
NEXT_PUBLIC_SOULWATCH_API_URL=http://localhost:8001
NEXT_PUBLIC_SOULGATE_API_URL=http://localhost:8002

# Cross-domain cookie domain (Portal Split Phase 3)
# Set to ".tiresias.network" in production so cookies are shared across
# tiresias.network and platform.tiresias.network. Leave empty/unset for
# local dev (subdomain cookies don't work on localhost).
# WARNING: Setting this causes a one-time session reset — all users must re-login.
COOKIE_DOMAIN=

# ---------------------------------------------------------------------------
# Tier 4 Piece A: MFA step-up + decrypt-scope audit reveal (chunk A2)
# ---------------------------------------------------------------------------
# Gate for the /v1/support/audit/{id}/decrypt endpoint. When false (default),
# the route returns 404 and is entirely dark. Flip to true ONLY in deployments
# that have MFA enrollment (chunk A3) and proxy image (A4) fully provisioned.
DECRYPT_ENDPOINT_ENABLED=false

# When true (default, recommended), auditor decrypt requests must present a
# valid single-use step-up JWT in X-Stepup-Token. Setting to false is for
# controlled break-glass only.
DECRYPT_ENFORCE_MFA=true

# HS256 shared secret (or RS256 PEM private key) for step-up JWT issuance.
# REQUIRED when DECRYPT_ENDPOINT_ENABLED=true. Leave empty for disabled.
STEPUP_JWT_SIGNING_KEY=
# Optional: HS256 (default) or RS256. For RS256, also set STEPUP_JWT_VERIFY_KEY.
STEPUP_JWT_ALGORITHM=HS256
STEPUP_JWT_VERIFY_KEY=
# Token lifetime in seconds. Default 60.
STEPUP_JWT_TTL_SECONDS=60
